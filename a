 -- Fling function (Admin+ rank)
local function flingPlayer(targetPlayer, executor)
    local character = executor.Character
    local targetChar = targetPlayer.Character
    
    if not character or not targetChar then
        addLog("Cannot fling: Missing character")
        return false
    end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
    
    if not rootPart or not targetRoot then
        addLog("Cannot fling: Missing HumanoidRootPart")
        return false
    end
    
    -- Teleport to target
    rootPart.CFrame = targetRoot.CFrame
    
    -- Apply extreme velocity (the fling)
    rootPart.Velocity = Vector3.new(99999999, 99999999, 99999999)
    rootPart.RotVelocity = Vector3.new(99999999, 99999999, 99999999)
    
    -- Optional: Break their joints for extra effect
    pcall(function()
        targetChar:BreakJoints()
    end)
    
    addLog(executor.Name .. " [" .. getPlayerRank(executor) .. "] FLUNG " .. targetPlayer.Name .. " [" .. getPlayerRank(targetPlayer) .. "]")
    return true
end

